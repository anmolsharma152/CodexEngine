# Groq API Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY=gsk_your_actual_api_key_here
GROQ_MODEL_NAME=llama-3.1-8b-instant

# Database Configuration
# If using the provided docker-compose:
# DB_URL="postgresql+psycopg://postgres:postgres@localhost:5432/codex_db"
DB_URL="postgresql+psycopg://user:password@localhost:5432/dbname"

# Security & CORS Configuration
# Secret key used to sign JWT session tokens
JWT_SECRET=your_production_jwt_secret_key_here
# Comma-separated list of allowed CORS origins (e.g. your Vercel deployment URL)
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app"
