# Groq API Configuration
GROQ_API_KEY=gsk_your_actual_api_key_here
GROQ_MODEL_NAME=llama-3.1-8b-instant

# Database Configuration (Neon / Supabase Postgres with pgvector)
DB_URL="postgresql+psycopg://user:password@host:5432/dbname"

# Supabase Project Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# Required for auto-creating the storage bucket on startup
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google Gemini API (for embeddings — free tier, 1500 RPM)
# Get key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Security & CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app"
